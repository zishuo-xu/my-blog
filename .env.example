# ===== 应用配置 =====
APP_NAME=MyBlog
DEBUG=true
# 前端地址，用于CORS配置
FRONTEND_URL=http://localhost:5173

# ===== 管理员账号（首次启动时自动创建） =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# ===== JWT鉴权配置 =====
JWT_SECRET_KEY=change_this_to_a_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
# Token有效期（天）
JWT_EXPIRE_DAYS=30

# ===== 数据库配置 =====
# SQLite数据库文件路径
DATABASE_URL=sqlite:///./blog.db

# ===== 图片上传配置 =====
# 图片存储根目录
UPLOAD_DIR=./app/static/upload
# 单文件最大体积（MB）
MAX_IMAGE_SIZE_MB=5
# 自动压缩阈值（MB），超过此大小自动压缩
COMPRESS_THRESHOLD_MB=2
# JPEG压缩质量（1-100，值越小文件越小，质量越低）
COMPRESS_QUALITY=85
# 允许的图片格式
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# ===== 存储类型配置 =====
# 可选：local / aliyun_oss / cloudflare_r2 / qiniu
STORAGE_TYPE=local

# ===== 阿里云OSS配置（STORAGE_TYPE=aliyun_oss时启用） =====
# 获取方式：阿里云控制台 → AccessKey管理 → 创建AccessKey
# 权限要求：OSS管理权限（AliyunOSSFullAccess 或自定义策略）
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# Endpoint 示例：oss-cn-hangzhou.aliyuncs.com（不含 https:// 前缀）
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET_NAME=your-bucket-name
#
# 提示：如果绑定了自定义域名/CDN，将 SITE_URL 改为自定义域名
# 例如：SITE_URL=https://img.yourdomain.com

# ===== Cloudflare R2配置（STORAGE_TYPE=cloudflare_r2时启用） =====
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_ACCESS_KEY_SECRET=
# R2_BUCKET_NAME=

# ===== 七牛云配置（STORAGE_TYPE=qiniu时启用） =====
# QINIU_ACCESS_KEY=
# QINIU_SECRET_KEY=
# QINIU_BUCKET_NAME=
# QINIU_DOMAIN=

# ===== 前端UI配置（可通过环境变量控制品牌色等） =====
# 品牌主色（十六进制，不含#）
BRAND_COLOR=165DFF
# 圆角大小（px）
BORDER_RADIUS=6

# ===== 站点配置 =====
SITE_URL=http://localhost:8000
SITE_NAME=My Blog
SITE_DESCRIPTION=A minimal personal blog
